{
  "name": "@maria-ms/components-web",
  "version": "1.0.0",
  "description": "Maria's Web Components.",
  "type": "module",
  "main": "./src/index.mjs",
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maria-ms/components-web.git"
  },
  "bugs": {
    "url": "https://github.com/maria-ms/components-web/issues"
  },
  "homepage": "https://github.com/maria-ms/components-web#readme",
  "exports": {
    ".": "./src/index.mjs",
    "./button": "./src/components/button/button.mjs",
    "./spinner": "./src/components/spinner/spinner.mjs",
    "./text-input": "./src/components/text-input/text-input.mjs",
    "./package.json": "./package.json"
  },
  "sideEffects": true,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "node --check scripts/link-skills.mjs && node --check scripts/unlink-skills.mjs && node --check src/index.mjs && node --check src/components/index.mjs && node --check src/components/button/button.mjs && node --check src/components/spinner/spinner.mjs && node --check src/components/text-input/text-input.mjs",
    "skills:link": "node scripts/link-skills.mjs",
    "skills:unlink": "node scripts/unlink-skills.mjs",
    "prepack": "npm run check",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@maria-ms/tokens": "1.0.0"
  }
}
